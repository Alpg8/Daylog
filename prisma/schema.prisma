// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  DISPATCHER
  DRIVER
}

enum VehicleStatus {
  AVAILABLE
  ON_ROUTE
  MAINTENANCE
  PASSIVE
}

enum TrailerStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  SOLD
}

enum OrderCategory {
  DOMESTIC
  IMPORT
  EXPORT
}

enum TradeType {
  ITH
  IHR
}

enum OrderStatus {
  PENDING
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
  TASK
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notifications Notification[]
  orders        Order[]        @relation("CreatedByUser")
}

model Vehicle {
  id            String        @id @default(uuid())
  plateNumber   String        @unique
  usageType     String? // YURTICI, YURTDISI
  ownershipType String? // OZMAL, KIRALIK
  brand         String?
  model         String?
  capacity      String?
  status        VehicleStatus @default(AVAILABLE)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  drivers     Driver[]
  orders      Order[]
  fuelRecords FuelRecord[]
}

model Trailer {
  id          String        @id @default(uuid())
  plateNumber String        @unique
  type        String?
  status      TrailerStatus @default(AVAILABLE)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orders Order[]
}

model Driver {
  id                         String    @id @default(uuid())
  fullName                   String
  phoneNumber                String?
  nationalId                 String?
  passportRemainingDays      Int?
  passportExpiryDate         DateTime?
  licenseRemainingDays       Int?
  licenseExpiryDate          DateTime?
  psychotechnicRemainingDays Int?
  psychotechnicExpiryDate    DateTime?
  assignedVehicleId          String?
  usageType                  String?
  ownershipType              String?
  isActive                   Boolean   @default(true)
  notes                      String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  assignedVehicle Vehicle?     @relation(fields: [assignedVehicleId], references: [id])
  orders          Order[]
  fuelRecords     FuelRecord[]
}

model Order {
  id              String        @id @default(uuid())
  serialNumber    Int?
  orderCategory   OrderCategory
  tradeType       TradeType?
  positionNumber  String?
  loadingDate     DateTime?
  unloadingDate   DateTime?
  operationDate   DateTime?
  pickupLocation  String?
  companyName     String?
  customerName    String?
  referenceNumber String?
  transportType   String?
  cargoNumber     String?
  tripNumber      String?
  invoiceNumber   String?
  routeText       String?
  cmrStatus       String?
  documentStatus  String?
  spanzetStanga   String?
  remaining       String?
  cita            String?
  vehicleId       String?
  trailerId       String?
  driverId        String?
  status          OrderStatus   @default(PENDING)
  notes           String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // ── Ortak yeni alanlar ──────────────────────
  sender          String?   // Gönderici
  recipient       String?   // Alıcı
  customs         String?   // Gümrük / Çıkış Kapısı

  // ── EXPORT alanları ─────────────────────────
  borderExitDate  DateTime? // Kapıkule Çıkış Tarihi
  customsGate     String?   // Gümrük / Çıkış Kapısı (export)
  loadingCountry  String?   // Yükleme Ülkesi
  unloadingCountry String?  // Boşaltma Ülkesi
  waitingPrice    Float?    // Bekleme Fiyatı
  freightPrice    Float?    // Nakliye Fiyatı
  customsCost     Float?    // Gümrük Masrafı
  supplyPrice     Float?    // Tedarik Fiyatı

  // ── IMPORT alanları ─────────────────────────
  supply          String?   // Tedarik (tedarikçi)
  loadingCity     String?   // Yükleme Şehri
  unloadingCity   String?   // Boşaltma Şehri
  unloadingWarehouse String? // Boşaltma Antrepo
  orderNumber     String?   // Order Numarası
  purchasePrice   Float?    // Alış Fiyatı
  salePrice       Float?    // Satış Fiyatı
  t2MrnNo        String?   // T2 MRN No

  // ── DOMESTIC alanları ───────────────────────
  rental          String?   // Kiralık
  containerTrailerNo String? // Konteynır-Dorse
  containerPickupAddress String? // Konteynır Alınacak Adres
  loadUnloadLocation String? // Yük-Boş Yer
  containerDropAddress String? // Konteynır Bırakılacak Adres
  deliveryCustomer String?  // Varış Müşterisi
  waitingDays     Int?      // Bekleme Gün
  freightSalePrice Float?   // Nakliye Satış Fiyatı
  waitingCustomsPrice Float? // Bekleme Güm. Uğrak Fiyatı
  customsKantarPrice Float? // Güm-kant Fiyatı
  supplierSalePrice Float?  // Tedarikçi Satış Fiyatı
  transportProfitRate Float? // Taşıma Kar Oranı
  supplierInfo    String?   // Tedarikçi Bilgileri
  supplierPhone   String?   // Tedarikçi Cep Numarası
  equipmentInfo   String?   // Ekipman Bilgisi

  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id])
  trailer       Trailer? @relation(fields: [trailerId], references: [id])
  driver        Driver?  @relation(fields: [driverId], references: [id])
  createdByUser User?    @relation("CreatedByUser", fields: [createdByUserId], references: [id])
}

model FuelRecord {
  id                 String   @id @default(uuid())
  vehicleId          String
  driverId           String?
  date               DateTime
  fuelStation        String?
  liters             Float?
  pricePerLiter      Float?
  totalCost          Float?
  startKm            Int?
  endKm              Int?
  distanceKm         Int?
  fuelType           String?
  paymentMethod      String?
  country            String?
  city               String?
  currency           String?
  tankInLiters       Float?
  tankRight          Float?
  tankLeft           Float?
  tankTotal          Float?
  tankOutLiters      Float?
  consumptionLiters  Float?
  averageConsumption Float?
  monthStartKm       Int?
  monthEndKm         Int?
  monthTotalKm       Int?
  monthFuelIn        Float?
  monthFuelOut       Float?
  fuelPurchased      Float?
  fuelUsed           Float?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver? @relation(fields: [driverId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}
