{
  "name": "daylog-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm --prefix website run dev --",
    "website": "npm --prefix website run dev --",
    "website:build": "npm --prefix website run build --",
    "website:start": "npm --prefix website run start --",
    "app:start": "npm --prefix app run start --",
    "data:migrate": "npm --prefix data run db:migrate --",
    "data:migrate:deploy": "npm --prefix data run db:migrate:deploy --",
    "data:studio": "npm --prefix data run db:studio --",
    "data:seed": "npm --prefix data run db:seed --",
    "data:reset": "npm --prefix data run db:reset --",
    "install:all": "npm install --prefix website && npm install --prefix app && npm install --prefix data",
    "deploy:website": "bash scripts/deploy-website.sh"
  }
}
