{
  "name": "daylog-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "website": "cd website && npm run dev",
    "website:build": "cd website && npm run build",
    "website:start": "cd website && npm run start",
    "app:start": "cd app && npm run start",
    "data:migrate": "cd data && npm run db:migrate",
    "data:migrate:deploy": "cd data && npm run db:migrate:deploy",
    "data:studio": "cd data && npm run db:studio",
    "data:seed": "cd data && npm run db:seed",
    "data:reset": "cd data && npm run db:reset",
    "install:all": "npm install --prefix website && npm install --prefix app && npm install --prefix data",
    "deploy:website": "bash scripts/deploy-website.sh"
  }
}
