{
  "name": "daylog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run db:generate",
    "dev": "cross-env NODE_ENV=development next dev",
    "prebuild": "npm run db:generate",
    "build": "cross-env NODE_ENV=production next build",
    "prestart": "npm run db:generate",
    "start": "cross-env NODE_ENV=production next start",
    "lint": "next lint",
    "db:generate": "prisma generate --schema=../data/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../data/prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --schema=../data/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --force --schema=../data/prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@hookform/resolvers": "^3.4.2",
    "@prisma/client": "^5.13.0",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@tanstack/react-table": "^8.16.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "jose": "^5.2.4",
    "lucide-react": "^0.372.0",
    "next": "14.2.3",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.4",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.38",
    "prisma": "^5.13.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "seed": "tsx ../data/prisma/seed.ts"
  }
}
